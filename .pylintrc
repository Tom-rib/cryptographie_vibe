[MASTER]
fail-under=8.0
load-plugins=

[MESSAGES CONTROL]
disable=
    missing-docstring,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    line-too-long,

[FORMAT]
max-line-length=120
indent-string='    '

[DESIGN]
max-attributes=7
max-bool-expr=5

[BASIC]
good-names=i,j,k,ex,Run,_

[SECURITY]
# Check for insecure-import-used and similar

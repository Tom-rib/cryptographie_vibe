    "4": "\u001b[95m",
    "5": "\u001b[96m",
    "6": "\u001b[97m",
    "7": "\u001b[36m",
    "8": "\u001b[35m",
    "9": "\u001b[34m"
  },
  "reset_color": "\u001b[0m"
}

